{
  "name": "nba-project-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --no-experimental-webstorage ./node_modules/next/dist/bin/next dev",
    "build": "node --no-experimental-webstorage ./node_modules/next/dist/bin/next build",
    "start": "node --no-experimental-webstorage ./node_modules/next/dist/bin/next start",
    "build:wasm": "wasm-pack build rust-sim --target web --out-dir ../lib/wasm-sim --out-name nba_sim"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "next": "^15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "22.10.0",
    "@types/react": "19.1.0",
    "typescript": "5.7.3"
  }
}
